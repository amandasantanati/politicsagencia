{
  "name": "politics-agencia",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i assets/css/style.css -o assets/css/style.min.css --minify",
    "build:js":  "terser assets/js/main.js -o assets/js/main.min.js --compress --mangle",
    "build":     "npm run build:css && npm run build:js",
    "dev":       "tailwindcss -i assets/css/style.css -o assets/css/style.min.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.39.0"
  }
}
